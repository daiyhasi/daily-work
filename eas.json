{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_PLAN_API_URL": "http://121.41.23.136/daily-work-api"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "simulator": {
      "env": {
        "EXPO_PUBLIC_PLAN_API_URL": "http://121.41.23.136/daily-work-api"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_PLAN_API_URL": "http://121.41.23.136/daily-work-api"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}

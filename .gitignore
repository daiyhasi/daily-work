# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# Native projects live in platform/. Root ios/ and android/ symlinks remain for Expo compatibility.
/platform/ios/Pods/
/platform/ios/build/
/platform/ios/DerivedData/
/platform/ios/.xcode.env.local
/platform/ios/**/*.xcuserdata/
/platform/ios/**/*.xcuserstate
/platform/ios/**/*.ipa
/platform/ios/**/*.jsbundle
